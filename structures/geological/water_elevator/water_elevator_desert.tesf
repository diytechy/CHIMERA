// Water Elevator -- DESERT roof variant (L1 = smooth sandstone). Roof cap at +4, then shaft.
str roof = "minecraft:smooth_sandstone";
for (num rx = 0; rx <= 3; rx = rx + 1) {
    for (num rz = 0; rz <= 3; rz = rz + 1) {
        block(rx, 4, rz, roof, true);
    }
}
structure(0, 0, 0, "water_elevator_core", "NONE");
