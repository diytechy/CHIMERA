// Dry-ground steam vent: a lit signal campfire (the signal_fire blockstate forces a
// tall smoke column) on the exposed apron, with a magma block beneath for the
// geothermal glow and open air above so the smoke can rise. Origin (0,0,0) is the air
// block on the surface; ground top is at -1.
//
block(0, -1, 0, "minecraft:campfire[lit=true,signal_fire=true]", true);
block(0, 0, 0, "minecraft:magma_block", true);
